PORT=4000
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=12h

# ─── Supabase ─────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard: Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service role key — bypasses RLS, used by backend only. NEVER expose to frontend.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── Data source toggle ──────────────────────────────────────────────
# "sqlite" (default) keeps using local apphr.db.
# "supabase" switches reads/writes to Supabase. Switch only after seeding.
DATA_SOURCE=sqlite
